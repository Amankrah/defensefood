# ──────────────────────────────────────────────
#  Rust
# ──────────────────────────────────────────────
/target/
crates/*/target/
**/*.rs.bk
Cargo.lock

# ──────────────────────────────────────────────
#  Python
# ──────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
*.egg
dist/
build/
.eggs/
*.so
*.dylib
*.pyd

# Virtual environments
.venv/
venv/
env/
backend/.venv/

# ──────────────────────────────────────────────
#  Maturin / PyO3 build artifacts
# ──────────────────────────────────────────────
*.whl
*.tar.gz
.maturin/

# ──────────────────────────────────────────────
#  Environment & secrets
# ──────────────────────────────────────────────
.env
.env.local
.env.production
*.pem

# ──────────────────────────────────────────────
#  Node.js / Next.js (frontend)
# ──────────────────────────────────────────────
node_modules/
food-defence/.next/
food-defence/out/
food-defence/.vercel

# ──────────────────────────────────────────────
#  IDE & OS
# ──────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# ──────────────────────────────────────────────
#  Data outputs (regenerated by pipelines)
# ──────────────────────────────────────────────
backend/script/output/*.csv
backend/script/output/analytics/
!backend/script/output/.gitkeep
